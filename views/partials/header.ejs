            <a href="/publicacoes" class="tab-btn <%= page === 'publicacoes' ? 'active' : '' %>" style="text-decoration: none; display: inline-flex; align-items: center;"><span class="tab-icon">⚖️</span>Justiça</a>
            <a href="/falhas" class="tab-btn <%= page === 'falhas' ? 'active' : '' %>" style="text-decoration: none; display: inline-flex; align-items: center;"><span class="tab-icon">⚠️</span>Pontos de Atenção</a>
