            <div class="header-subtitle">do Rio de Janeiro</div>
        </div>
    </div>
    <div class="header-right">
        <nav class="tab-nav">
            <a href="/" class="tab-btn <%= page === 'inicio' ? 'active' : '' %>" style="text-decoration: none; display: inline-flex; align-items: center;">
                <span class="tab-icon">🏠</span>Início
            </a>
            <a href="/perfil" class="tab-btn <%= page === 'perfil' ? 'active' : '' %>" style="text-decoration: none; display: inline-flex; align-items: center;">
